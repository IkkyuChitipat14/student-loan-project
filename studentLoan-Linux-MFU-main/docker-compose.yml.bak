services:
  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    ports:
      - "${VUE_APP_API_PORT:-1080}:${VUE_APP_API_PORT:-1080}"  # Default to 1080 if not set
    env_file:
      - ./frontend/.env
    volumes:
      - ./frontend:/app
    depends_on:
      - backend

  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    ports:
      - "8080:8080"  # Maps the container's port to the host machine
    env_file:
      - ./backend/.env  # Loads the .env file
    volumes:
      - ./backend:/app  # Mounts the local directory to the container
      - loan_files:/app/uploads/loan_files  # Uses the loan_files volume for uploads
    depends_on:
      - mysql  # Ensures MySQL is available before the backend starts

  mysql:
    image: mysql:latest
    ports:
      - "3308:3306"  # Default to 3308 if not set
    environment:
      - MYSQL_ROOT_PASSWORD=${MYSQL_ROOT_PASSWORD:-rootpassword}
      - MYSQL_DATABASE=${MYSQL_DATABASE:-Student_loan}
      - MYSQL_USER=${MYSQL_USER:-myuser}
      - MYSQL_PASSWORD=${MYSQL_PASSWORD:-mypassword}
    volumes:
      - mysql_data:/var/lib/mysql
    healthcheck:
      test:
        [
          "CMD",
          "mysqladmin",
          "ping",
          "-h",
          "localhost",
          "-u",
          "root",
          "-p${MYSQL_ROOT_PASSWORD}",
        ]
      interval: 10s
      timeout: 5s
      retries: 5

  phpmyadmin:
    image: phpmyadmin/phpmyadmin
    container_name: phpmyadmin
    ports:
      - "8082:80"  # Port 8081 on your PC will be mapped to port 80 in the phpMyAdmin container
    environment:
      - MYSQL_ROOT_PASSWORD=${MYSQL_ROOT_PASSWORD:-rootpassword}  
      - PMA_HOST=mysql
      - PMA_PORT=3306   # Default MySQL port
    depends_on:
      - mysql

#  nginx:
#    container_name: mynginx_studenLoan
#    image: nginx:latest
#    ports:
#      - "8085:8085"   # HTTP on 8085
#      - "8443:8443"   # HTTPS on 8443
#    volumes:
#      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro  # Nginx configuration
#      - ./nginx/ssl:/etc/nginx/ssl  # SSL certificates
#    depends_on:
#      - frontend
#      - backend

volumes:
  mysql_data:
  loan_files:  # Define the loan_files volume here

